# Copy to .env.production for `npm run build` (values are baked in at build time).

# Option A — API on the same host as the site: leave both unset. Your reverse proxy must
# forward these paths to FastAPI: /stories /health /uploads /ws (and optionally /docs).
# VITE_API_BASE=
# VITE_WS_URL=

# Option B — API on another origin (e.g. https://api.yourdomain.com):
# VITE_API_BASE=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com/ws
