# Vite loads .env.development.local for `npm run dev` and .env.production for `npm run build`.
# Copy the block you need; these files are gitignored.

# --- Local dev → local API (default if unset) ---
# No file needed. Dev server uses http://localhost:8000 and ws://localhost:8000/ws.

# --- Local dev → production API (same stories as theartisonian.com) ---
# Save as .env.development.local, restart `npm run dev`:
# VITE_API_BASE=https://theartisonian.com
# VITE_WS_URL=wss://theartisonian.com/ws

# --- Production build (deployed site) ---
# Option A — API on the same host: leave both unset. Reverse proxy must forward
# /stories /health /uploads /ws (and optionally /docs) to FastAPI.
# VITE_API_BASE=
# VITE_WS_URL=

# Option B — API on another origin:
# VITE_API_BASE=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com/ws
